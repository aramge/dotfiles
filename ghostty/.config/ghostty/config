# Schrift & Größe (Goldstandard für Ergonomie)
font-family = "JetBrains Mono"
font-size = 14

# Fenstergröße
window-width = 80
window-height = 25

# --- DEIN FIX ---
# Linke Option-Taste = Meta (für Emacs/tmux)
# Rechte Option-Taste = macOS Standard (für @, |, ~, etc.)
macos-option-as-alt = left

clipboard-write = allow

# Optik (KISS)
theme = catppuccin-mocha
window-padding-x = 15
window-padding-y = 15
window-decoration = true
